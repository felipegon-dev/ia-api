{
  "name": "ia-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prod": "pm2-runtime run/www.prod.js",
    "prod:worker": "pm2-runtime run/worker-redis.prod.js",
    "build": "tsc --project tsconfig.json",
    "worker": "ts-node -r tsconfig-paths/register run/worker-redis.ts",
    "dev": "nodemon --watch src --watch run --ext ts,tsx,js,json run/www"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dotenv": "^17.2.3",
    "express": "~4.16.1",
    "express-rate-limit": "^8.5.0",
    "http-errors": "~1.6.3",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lz-string": "^1.5.0",
    "morgan": "~1.9.1",
    "mysql2": "^3.15.3",
    "node-fetch": "^3.3.2",
    "pm2": "^5.4.3",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.8.3"
  }
}
